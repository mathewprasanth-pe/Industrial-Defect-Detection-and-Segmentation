cat >> .gitignore << 'EOF'

# ---- Project-specific: MVTec AD data & artifacts ----

# Dataset (large, downloaded separately — not committed)
data/

# Model weights / checkpoints
*.pth
*.pt
*.ckpt
*.safetensors

# Cached feature extractions (memory banks, embeddings)
*.npy
*.npz
features_cache/
memory_bank/

# Results — keep the metrics table, ignore bulky generated images
results/qualitative_examples/*.png
results/qualitative_examples/*.jpg
!results/qualitative_examples/.gitkeep

# macOS clutter
.DS_Store
.AppleDouble
.LSOverride

# HuggingFace / timm model download cache (if it lands in-project)
.cache/
EOF